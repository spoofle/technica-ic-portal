rules_version = '2';

// =========================================================================
// Firestore security rules for Technica Inclusive Communities
// -------------------------------------------------------------------------
// Two roles live on each user's profile (users/{uid}.role):
//   - "student"    : can read/write only their own profile + progress.
//   - "instructor" : can additionally READ every student's profile and
//                    progress, and READ/WRITE the shared lessons collection.
//
// SECURITY NOTE: the instructor invite code checked at signup is enforced
// only in the browser, so it is convenience gating — NOT real security. The
// meaningful protections here are:
//   1. A user may only create/update their OWN user doc.
//   2. A user may NOT change their own `role` after the doc is created
//      (the update rule pins role to its existing value).
// A determined user could still self-assign role:"instructor" at create
// time via the SDK. If you need true security, set the role via Firebase
// custom claims from a Cloud Function (validating the code server-side) and
// replace isInstructor() below with `request.auth.token.role == 'instructor'`.
//
// Deploy with:  firebase deploy --only firestore:rules
// =========================================================================
service cloud.firestore {
  match /databases/{database}/documents {

    // Role of the user making the request (reads their own profile doc).
    function requesterRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isInstructor() {
      return request.auth != null && requesterRole() == 'instructor';
    }

    // A user's profile document: users/{uid}
    match /users/{userId} {
      // Read own profile; instructors may read any profile (roster + detail).
      allow read: if request.auth != null
                  && (request.auth.uid == userId || isInstructor());

      // Create only your OWN doc, with role limited to the two allowed values.
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.role in ['student', 'instructor'];

      // Update your own doc, but you may NOT change your role (anti-escalation).
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.role == resource.data.role;

      allow delete: if false;

      // A user's lesson progress: users/{uid}/progress/{lessonId}
      match /progress/{lessonId} {
        // Students read/write their own; instructors may READ any (read-only).
        allow read: if request.auth != null
                    && (request.auth.uid == userId || isInstructor());
        allow write: if request.auth != null
                     && request.auth.uid == userId;
      }
    }

    // Shared curriculum: lessons/{lessonId}
    // Students may READ only PUBLISHED lessons (checked first so the common
    // case needs no extra get()); instructors may READ all and WRITE.
    // NOTE: students must query lessons with where("published","==",true) — an
    // unfiltered query would be rejected because it could return hidden docs.
    match /lessons/{lessonId} {
      allow read: if request.auth != null
                  && (resource.data.published == true || isInstructor());
      allow write: if isInstructor();
    }

    // Everything else is denied by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
