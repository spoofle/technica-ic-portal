# Firebase config — copy this file to ".env" and fill in your project's values.
# Find these in Firebase Console > Project settings > General > "Your apps".
# The ".env" file is gitignored so your config never gets committed.

VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:abcdef123456

# Instructor sign-up invite code. Anyone who picks "Instructor" at sign-up must
# enter this code. NOTE: this is checked in the browser, so it's a friendly gate
# only — the Firestore rules are what actually protect data. Pick any secret
# string and share it with your instructors.
VITE_INSTRUCTOR_INVITE_CODE=change-me-instructor-code

# Optional preview switches (leave unset in production):
# VITE_BYPASS_AUTH=true        # skip the sign-in requirement for local preview
# VITE_BYPASS_ROLE=instructor  # preview instructor views in bypass mode
